# ENTSO-E Transparency Platform API key
# Register at https://transparency.entsoe.eu/
ENTSOE_API_KEY=your_entsoe_api_key_here

# Default bidding zone used by the CLI when --zone is not passed.
# Examples:
#   10YDE-EL------O  Germany
#   10YAT-APG------L Austria
#   10YCH----------C Switzerland
#   10YFR-1-----R    France
#   10YGB-2--------  Great Britain
DEFAULT_AREA=10YDE-EL------O

# Ollama runs locally; the agent expects:
#   - chat model:       deepseek-r1:8b
#   - embedding model:  nomic-embed-text
# Pull them with:
#   ollama pull deepseek-r1:8b
#   ollama pull nomic-embed-text

# LangSmith tracing (optional — used by eval upload and agent tracing)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=vpp-rag-agent
# LANGSMITH_API_KEY=your_langsmith_api_key_here
